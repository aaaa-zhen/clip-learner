# ---- LLM for analysis (humor/slang/quiz) ----
# Uses OpenAI-SDK-compatible endpoints. Settings can also be changed in-app
# via the Settings modal; env vars are the fallback.
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://aihubmix.com/v1
ANTHROPIC_MODEL=gpt-5.4-mini

# ---- Whisper transcription (replaces YouTube caption fetch) ----
# If WHISPER_API_KEY is set, we use an OpenAI-compatible Whisper API (fast).
# Otherwise the server falls back to the local `whisper` CLI (free, slower).
WHISPER_API_KEY=
# OpenAI:    https://api.openai.com/v1
# AIHubMix:  https://aihubmix.com/v1
# Groq:      https://api.groq.com/openai/v1   (use model=whisper-large-v3-turbo)
WHISPER_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=whisper-1

# Local whisper CLI settings (used only when WHISPER_API_KEY is empty).
# Options: tiny.en | base.en | small.en | medium.en. tiny.en ≈ 7× realtime on CPU.
WHISPER_LOCAL_MODEL=tiny.en

# Tuning (optional). Keep MAX_PARALLEL_CHUNKS ≤ 2 on rate-limited providers.
# WHISPER_CHUNK_SECONDS=600
# WHISPER_MAX_PARALLEL_CHUNKS=2

# ---- yt-dlp / YouTube network tuning (optional) ----
# Export a browser Netscape cookies file here if YouTube asks for sign-in
# or blocks your VPS. By default the app looks for ./cookies.txt.
# YTDLP_COOKIES=/absolute/path/to/cookies.txt
#
# Use a proxy when the server network cannot reach YouTube reliably.
# Examples: socks5://127.0.0.1:1080 or http://127.0.0.1:7890
# YTDLP_PROXY=
#
# Default true. Helps on VPS networks with broken IPv6 routes to YouTube.
# YTDLP_FORCE_IPV4=true
#
# Default ejs:github. Required for YouTube JS challenges on many VPS IPs.
# YTDLP_REMOTE_COMPONENTS=ejs:github
#
# Full yt-dlp process retries for transient TLS EOF / connection reset errors.
# YTDLP_PROCESS_RETRIES=3
#
# Last-resort workaround for broken TLS interception/proxy environments.
# Prefer fixing cert/proxy/yt-dlp first; only enable if needed.
# YTDLP_NO_CHECK_CERTIFICATE=false
